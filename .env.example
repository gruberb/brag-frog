# Brag Frog — Environment Variables
# Copy this file to .env and fill in the required values.

# ── Required ──────────────────────────────────────────────

# Google OAuth 2.0 credentials
# Create at: https://console.cloud.google.com/apis/credentials
BRAGFROG_GOOGLE_CLIENT_ID=your-google-client-id
BRAGFROG_GOOGLE_CLIENT_SECRET=your-google-client-secret

# Encryption key for API tokens stored in the database
# Generate with: openssl rand -base64 32
BRAGFROG_ENCRYPTION_KEY=your-base64-encoded-32-byte-key

# ── Optional ──────────────────────────────────────────────

# Public base URL (used for OAuth redirects)
# BRAGFROG_BASE_URL=https://bragfrog.example.com

# Show "Brag Frog | Acme Corp" on the login page
# BRAGFROG_INSTANCE_NAME=Acme Corp

# Restrict sign-ups to a specific email domain
# BRAGFROG_ALLOWED_DOMAIN=your-company.com

# Only sync public/non-confidential data from all services
# BRAGFROG_PUBLIC_ONLY=false

# Anthropic model for AI-powered self-review drafts
# BRAGFROG_AI_MODEL=claude-sonnet-4-5-20250929

# Server bind address and port
# BRAGFROG_HOST=0.0.0.0
# BRAGFROG_PORT=8080

# SQLite database file path
# BRAGFROG_DATABASE_PATH=bragfrog.db
